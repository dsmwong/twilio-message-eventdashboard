# Twilio credentials are injected automatically by twilio-run / serverless runtime:
#   ACCOUNT_SID, AUTH_TOKEN
#
# This dashboard additionally requires:

# Sync Service SID — create with: twilio api:sync:v1:services:create --friendly-name message-event-dashboard
SYNC_SERVICE_SID=

# API Key + Secret used to mint short-lived Access Tokens for the browser's Sync client.
# Create with: twilio api:core:keys:create --friendly-name message-event-dashboard
TWILIO_API_KEY=
TWILIO_API_SECRET=

# 32-byte hex secret used to HMAC-sign the admin session cookie.
# Generate with: pnpm run session:secret
SESSION_SECRET=

# Twilio Verify Service used to confirm new approved destinations.
# Provision/find with: pnpm run verify:bootstrap
VERIFY_SERVICE_SID=
