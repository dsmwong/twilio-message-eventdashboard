{
  "name": "twilio-message-eventdashboard",
  "version": "0.1.0",
  "private": true,
  "description": "Dashboard to compare Twilio Programmable Messaging StatusCallback vs Event Streams side-by-side.",
  "scripts": {
    "build:web": "pnpm --filter web build && node scripts/copy-assets.mjs",
    "build": "pnpm run build:web",
    "dev:web": "pnpm --filter web dev",
    "dev:functions": "twilio-run --env .env",
    "start": "twilio-run --env .env",
    "deploy": "pnpm run build && twilio serverless:deploy --env .env.deploy",
    "refresh:senders": "node scripts/refresh-senders.mjs",
    "backfill:optout": "node scripts/backfill-optout.mjs"
  },
  "devDependencies": {
    "twilio-run": "^4.1.2"
  },
  "dependencies": {
    "@twilio/runtime-handler": "2.0.3",
    "twilio": "5.13.1"
  },
  "engines": {
    "node": ">=20 <=22"
  },
  "packageManager": "pnpm@10.12.1"
}
